{
  "name": "@git-cms/core",
  "version": "0.1.0",
  "description": "Git-based CMS for Next.js - Store content as markdown in GitHub",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./next/page": {
      "types": "./dist/next/admin-page.d.ts",
      "default": "./dist/next/admin-page.js"
    },
    "./next/route": {
      "types": "./dist/next/dispatcher.d.ts",
      "default": "./dist/next/dispatcher.js"
    },
    "./markdown": {
      "types": "./dist/lib/markdown.d.ts",
      "default": "./dist/lib/markdown.js"
    },
    "./nav": {
      "types": "./dist/lib/nav.d.ts",
      "default": "./dist/lib/nav.js"
    },
    "./styles": "./dist/git-cms.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:css",
    "build:ts": "tsc",
    "build:css": "tailwindcss -i src/styles/input.css -o dist/git-cms.css --minify",
    "dev": "concurrently \"tsc --watch\" \"tailwindcss -i src/styles/input.css -o dist/git-cms.css --watch\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "next-auth": "^5.0.0-beta.25",
    "tailwind-merge": "^2.5.5",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "cms",
    "nextjs",
    "markdown",
    "github",
    "git-based-cms",
    "headless-cms"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/git-cms"
  },
  "license": "MIT"
}
